# Copie ce fichier en .env et remplis tes vraies valeurs
# Ne commite JAMAIS ton .env (il est dans .gitignore)

# Personal Access Token Airtable (commence par "pat...")
# → https://airtable.com/create/tokens
VITE_AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Base ID (commence par "app...")
# → Visible dans l'URL : airtable.com/appXXXXXXXXXXXXXX/...
VITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
